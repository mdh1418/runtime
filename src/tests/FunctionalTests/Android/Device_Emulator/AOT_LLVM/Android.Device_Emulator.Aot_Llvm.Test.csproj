<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <MonoForceInterpreter>false</MonoForceInterpreter>
    <RunAOTCompilation>true</RunAOTCompilation>
    <ForceFullAOT>true</ForceFullAOT>
    <TestRuntime>true</TestRuntime>
    <TargetFramework>$(NetCoreAppCurrent)</TargetFramework>
    <MainLibraryFileName>Android.Device_Emulator.Aot_Llvm.Test.dll</MainLibraryFileName>
    <ExpectedExitCode>42</ExpectedExitCode>
    <EnableAggressiveTrimming>true</EnableAggressiveTrimming>
    <MonoEnableLLVM>true</MonoEnableLLVM>
  </PropertyGroup>

  <PropertyGroup>
    <NativeLibrary>shared</NativeLibrary>
    <AndroidGenerateAppBundle>true</AndroidGenerateAppBundle>
  </PropertyGroup>
  <ItemGroup>
    <DirectPInvokes Include="mdh!mdh" />
    <DirectPInvokeSources Include="$(MSBuildThisFileDirectory)mdh.c" />
    <_ExtraLibrarySources Include="$(MSBuildThisFileDirectory)mdh.c" />
    <TrimmerRootDescriptor Include="$(MSBuildThisFileDirectory)ILLink.Descriptor.Android.Device_Emulator.Aot_Llvm.Test.xml" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="Program.cs" />
  </ItemGroup>
</Project>
